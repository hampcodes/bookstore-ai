# Perfil de Spring Boot (dev = local con Docker, prod = Render con Supabase)
SPRING_PROFILES_ACTIVE=dev

# Base de datos
DB_NAME=bookstore_ai_db
DB_USER=postgres
DB_PASSWORD=adminadmin

# pgAdmin (para ver la base de datos en local)
PGADMIN_EMAIL=admin@bookstore.com
PGADMIN_PASSWORD=admin123

# JWT — cualquier texto largo de más de 64 caracteres
JWT_SECRET=cambia_esto_por_cualquier_texto_largo_minimo_64_caracteres_aqui

# OpenAI — obligatorio para que funcione la IA
OPENAI_API_KEY=sk-...

# Cors — orígenes permitidos para hacer peticiones a la API desde el frontend
CORS_ALLOWED_ORIGINS=http://localhost:4200
